{
  "name": "dynamic-openapi-mcp",
  "version": "0.1.6",
  "description": "Transform any OpenAPI v3 spec into a fully functional MCP server",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "dynamic-openapi-mcp": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:run": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "openapi",
    "mcp",
    "model-context-protocol",
    "ai",
    "llm",
    "tools"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "dynamic-openapi-tools": "^1.1.4",
    "zod": "^3.24.2",
    "zod-to-json-schema": "^3.24.3"
  },
  "devDependencies": {
    "@types/node": "^25.2.2",
    "@vitest/coverage-v8": "^3.2.4",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "pnpm": {
    "overrides": {
      "hono": "^4.12.14",
      "@hono/node-server": "^1.19.13",
      "qs": "^6.14.2",
      "express-rate-limit": "^8.2.2",
      "path-to-regexp": "^8.4.0",
      "ajv": "^8.18.0",
      "yaml": "^2.8.3"
    }
  }
}
